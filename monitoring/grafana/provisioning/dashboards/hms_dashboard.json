{
  "uid": "hms-overview",
  "title": "HMS Microservices Overview",
  "tags": ["hms"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "15s",
  "panels": [
    {
      "id": 1, "type": "stat",
      "title": "Appointments Created (Total)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "appointments_created_total", "legendFormat": "Total" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "id": 2, "type": "stat",
      "title": "Failed Payments (Total)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "payments_failed_total", "legendFormat": "Failed" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } }
    },
    {
      "id": 3, "type": "stat",
      "title": "Bills Created (Total)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "bills_created_total", "legendFormat": "Bills" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 4, "type": "stat",
      "title": "Appointments Cancelled (Total)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "appointments_cancelled_total", "legendFormat": "Cancelled" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "orange", "value": null }] } } }
    },
    {
      "id": 5, "type": "timeseries",
      "title": "Appointments Created Rate (per min)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{ "expr": "rate(appointments_created_total[1m]) * 60", "legendFormat": "Appointments/min" }]
    },
    {
      "id": 6, "type": "timeseries",
      "title": "Bill Creation Latency (p50 / p95 ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(bill_creation_latency_ms_bucket[1m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(bill_creation_latency_ms_bucket[1m]))", "legendFormat": "p95" }
      ]
    },
    {
      "id": 7, "type": "timeseries",
      "title": "HTTP Requests by Service",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "targets": [{ "expr": "rate(http_requests_total[1m]) * 60", "legendFormat": "{{service}} {{method}} {{status}}" }]
    },
    {
      "id": 8, "type": "timeseries",
      "title": "Payments Recorded vs Failed",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "targets": [
        { "expr": "rate(payments_recorded_total[1m]) * 60", "legendFormat": "Successful/min" },
        { "expr": "rate(payments_failed_total[1m]) * 60", "legendFormat": "Failed/min" }
      ]
    }
  ]
}